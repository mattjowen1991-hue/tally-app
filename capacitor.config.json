{
  "appId": "com.tally.billtracker",
  "appName": "Tally",
  "webDir": "www",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0a0e27",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "LIGHT",
      "backgroundColor": "#0a0e27",
      "overlaysWebView": true
    },
    "GoogleAuth": {
      "scopes": ["profile", "email"],
      "serverClientId": "135467683617-n5sck8vo4ot0h35lmbepc064d7legva1.apps.googleusercontent.com",
      "forceCodeForRefreshToken": true
    }
  },
  "ios": {
    "contentInset": "always"
  },
  "android": {
    "allowMixedContent": true
  }
}
